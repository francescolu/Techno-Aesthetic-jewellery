# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# IDE 配置文件
.vscode/
.idea/
*.swp
*.swo

# 临时文件
*.tmp
*.log
*.bak
*~

# 工作空间配置
.workbuddy/

# 大文件
*.zip
*.rar
*.7z

# PDF (如果不想提交生成的PDF)
# *.pdf

# Word 文档 (如果不想提交)
# *.docx
# *.doc

# Excel (如果不想提交)
# *.xlsx
# *.xls

# 图片 (如果有很多临时图片)
# images/
# !images/*.jpg
# !images/*.png

# 参考资料 (如果包含大量文件)
references/*.pdf
references/*.docx
references/*.epub

# 节点模块 (如果有前端代码)
node_modules/

# Python (如果有 Python 脚本)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
